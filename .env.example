# ──────────────────────────────────────────────────────────────────────────
# SafetyIQ — Reliance Predictive Safety Technologies
# Environment variables — copy to .env.local and fill in real values.
# Never commit real secrets to source control.
# ──────────────────────────────────────────────────────────────────────────

# Supabase (browser + server). Public values, safe to expose to the client.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI engine — SERVER ONLY. Used by the SafetyIQ Predictability Engine routes.
# The engine is provider-agnostic. Set SAFETYIQ_AI_PROVIDER to pick one, or
# leave unset to infer from whichever key is present (Anthropic preferred).
# SAFETYIQ_AI_PROVIDER=anthropic        # openai | anthropic
OPENAI_API_KEY=your-openai-key
SAFETYIQ_AI_MODEL=gpt-4o-mini
# Anthropic (Claude) — preferred provider for EHS analysis reasoning quality.
# claude-haiku-4-5 is cost-matched to gpt-4o-mini for routine scans;
# claude-sonnet-4-6 for compliance gap and chemical hazard analysis.
# ANTHROPIC_API_KEY=your-anthropic-key
# SAFETYIQ_ANTHROPIC_MODEL=claude-sonnet-4-6

# Embedding model for pgvector similarity (chemical matching, similar incidents).
SAFETYIQ_EMBED_MODEL=text-embedding-3-small

# Protects the scheduled Predictability Engine cron route (/api/cron/predict).
# Vercel Cron sends this as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=your-cron-secret

# App
SAFETYIQ_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Demo / mock mode. When set to "true" (or when Supabase keys are absent),
# SafetyIQ serves deterministic in-memory fixture data — every screen and
# module is fully explorable without a live backend or AI keys.
# Demo org: BioStar Research Inc. | Demo user: Sarah Chen (EHS Manager)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SAFETYIQ_MOCK=true
