{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "src/app/api/devcenter/generate-implementation/route.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/pclss",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/agent-standup",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/cron/gateway-agent",
      "schedule": "30 12 * * *"
    }
  ]
}
